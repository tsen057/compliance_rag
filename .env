# Copy this to .env — no API keys needed for the local HuggingFace setup.

LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Paths (defaults are fine for local dev)
DOCS_DIR=data/docs
VECTORSTORE_DIR=data/vectorstore

# Models (local, free — no API key required)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=google/flan-t5-base
LLM_MAX_NEW_TOKENS=512

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
DEFAULT_TOP_K=5

# ── Optional: switch to Azure OpenAI ─────────────────────────────────────────
# Uncomment and fill these in, then update agent.py to use AzureChatOpenAI.
# AZURE_OPENAI_API_KEY=your_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
